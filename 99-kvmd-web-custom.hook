# Installed by deploy.sh to /etc/pacman.d/hooks/99-kvmd-web-custom.hook
# Re-clones custom web UI after kvmd package update.

[Trigger]
Operation = Upgrade
Type = Package
Target = kvmd

[Action]
Description = Re-deploying custom web UI after kvmd update...
When = PostTransaction
Exec = /bin/bash -c "cd /usr/share/kvmd && rm -rf web && git clone https://github.com/vewe-richard/pi-kvm-customize.git web"
